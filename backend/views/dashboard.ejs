<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <title>Resumate - Dashboard</title>
  <style>
    :root {
      --primary: #76b900; /* NVIDIA Green */
      --text-main: #000000;
      --text-muted: #666666;
      --border: #d1d1d1;
      --bg: #ffffff;
      --font-family: 'Inter', sans-serif;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: var(--font-family);
      background-color: var(--bg);
      color: var(--text-main);
      line-height: 1.6;
      padding: 40px 20px;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .container {
      width: 100%;
      max-width: 900px;
    }

    header {
      text-align: center;
      margin-bottom: 60px;
    }

    header h1 {
      font-size: 3.5rem;
      font-weight: 800;
      letter-spacing: -2px;
      margin-bottom: 20px;
    }

    header p {
      color: var(--text-muted);
      font-size: 1.1rem;
      max-width: 600px;
      margin: 0 auto;
    }

    .form-container {
      display: flex;
      flex-direction: column;
      gap: 30px;
    }

    .section-title {
      font-size: 1.8rem;
      font-weight: 700;
      margin: 40px 0 20px;
      padding-bottom: 15px;
      border-bottom: 2px solid #f0f0f0;
      color: var(--text-main);
      display: flex;
      align-items: center;
      gap: 15px;
    }

    .section-title span {
      background: var(--primary);
      color: white;
      width: 32px;
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 4px;
      font-size: 1rem;
    }

    .form-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      column-gap: 40px;
      row-gap: 30px;
    }

    @media (max-width: 768px) {
      .form-grid {
        grid-template-columns: 1fr;
      }
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .form-group.full-width {
      grid-column: 1 / -1;
    }

    .form-group label {
      font-size: 1.05rem;
      font-weight: 500;
      color: var(--text-muted);
    }

    .form-group input, .form-group textarea {
      padding: 14px 18px;
      border: 1px solid var(--border);
      border-radius: 4px;
      font-size: 1.1rem;
      background-color: #fcfcfc;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    .form-group input:focus, .form-group textarea:focus {
      outline: none;
      border-color: var(--text-main);
      background-color: #fff;
    }

    .dynamic-section {
      background: #fafafa;
      border-radius: 8px;
      padding: 30px;
      margin-bottom: 30px;
    }

    .dynamic-item {
      display: flex;
      flex-direction: column;
      gap: 25px;
      padding: 25px;
      background: white;
      border: 1px solid #eeeeee;
      border-radius: 6px;
      margin-bottom: 20px;
    }

    .alert {
      padding: 20px;
      border-radius: 6px;
      margin-bottom: 40px;
      text-align: center;
      font-weight: 600;
      font-size: 1.1rem;
    }

    .alert-success {
      background-color: #e6fffa;
      color: #2c7a7b;
      border: 1px solid #b2f5ea;
    }

    .alert-error {
      background-color: #fff5f5;
      color: #c53030;
      border: 1px solid #feb2b2;
    }

    .save-button-container {
      margin-top: 60px;
      display: flex;
      justify-content: center;
    }

    .btn-submit {
      background-color: var(--text-main);
      color: #ffffff;
      padding: 18px 50px;
      font-size: 1.2rem;
      font-weight: 700;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      transition: background-color 0.2s, transform 0.1s;
    }

    .btn-submit:hover {
      background-color: #333333;
    }

    .btn-submit:active {
      transform: scale(0.98);
    }

    .skills-container {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 15px;
    }

    .skill-tag {
      padding: 6px 14px;
      background: #eeeeee;
      border-radius: 4px;
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--text-muted);
    }

    .number-prefix {
      color: var(--text-muted);
      margin-right: 8px;
    }

  </style>
</head>
<body>
  <div class="container">
    <header>
      <h1>Resumate Profile</h1>
      <p>Clean, efficient, and professional profile management. Manage your data exactly how leading companies see it.</p>
    </header>

    <% if (message) { %>
      <div class="alert <%= isSuccess ? 'alert-success' : 'alert-error' %>">
        <%= message %>
      </div>
    <% } %>

    <form action="/update-resume/<%= userId %>" method="POST" class="form-container">
      
      <div class="section-title"><span>1</span> Basic Information</div>
      <div class="form-grid">
        <div class="form-group full-width">
          <label><span class="number-prefix">1.</span> Full Name *</label>
          <input type="text" name="name" value="<%= parsedResume.name || userName %>" placeholder="e.g. Darshit Khandelwal" required>
        </div>

        <div class="form-group">
          <label><span class="number-prefix">2.</span> Email Address *</label>
          <input type="email" name="email" value="<%= parsedResume.email %>" placeholder="e.g. name@example.com" required>
        </div>

        <div class="form-group">
          <label><span class="number-prefix">3.</span> Contact Phone</label>
          <input type="text" name="phone" value="<%= parsedResume.phone %>" placeholder="e.g. +91 00000 00000">
        </div>

        <div class="form-group">
          <label><span class="number-prefix">4.</span> LinkedIn Profile</label>
          <input type="text" name="linkedIn" value="<%= parsedResume.linkedIn %>" placeholder="linkedin.com/in/username">
        </div>

        <div class="form-group">
          <label><span class="number-prefix">5.</span> GitHub Profile</label>
          <input type="text" name="github" value="<%= parsedResume.github %>" placeholder="github.com/username">
        </div>
      </div>

      <div class="section-title"><span>2</span> Skills & Competencies</div>
      <div class="form-group">
        <label><span class="number-prefix">6.</span> Professional Skills (comma separated)</label>
        <textarea name="skills" rows="4" placeholder="e.g. React, Node.js, Python, AWS"><%= parsedResume.skills.join(", ") %></textarea>
        <div class="skills-container">
          <% parsedResume.skills.slice(0, 10).forEach(skill => { %>
            <span class="skill-tag"><%= skill %></span>
          <% }) %>
        </div>
      </div>

      <div class="section-title"><span>3</span> Work Experience</div>
      <div class="dynamic-section">
        <% parsedResume.workExperience.forEach((work, index) => { %>
          <div class="dynamic-item">
            <div class="form-grid">
              <div class="form-group">
                <label><span class="number-prefix">7.</span> Organization / Company</label>
                <input type="text" name="workExperience[<%= index %>][company]" value="<%= work.company %>" placeholder="Organization name">
              </div>
              <div class="form-group">
                <label><span class="number-prefix">8.</span> Job Role / Position</label>
                <input type="text" name="workExperience[<%= index %>][role]" value="<%= work.role %>" placeholder="Your role">
              </div>
              <div class="form-group full-width">
                <label><span class="number-prefix">9.</span> Duration / Timeline</label>
                <input type="text" name="workExperience[<%= index %>][duration]" value="<%= work.duration %>" placeholder="e.g. Jan 2021 - Present">
              </div>
            </div>
          </div>
        <% }) %>
        <% if (parsedResume.workExperience.length === 0) { %>
          <p style="color: var(--text-muted); text-align: center;">No work experience detected. Add items to your resume to populate this section.</p>
        <% } %>
      </div>

      <div class="section-title"><span>4</span> Education Background</div>
      <div class="dynamic-section" style="border-top: 5px solid #f0f0f0;">
        <% parsedResume.education.forEach((edu, index) => { %>
          <div class="dynamic-item">
            <div class="form-grid">
              <div class="form-group full-width">
                <label><span class="number-prefix">10.</span> Institution / University</label>
                <input type="text" name="education[<%= index %>][university]" value="<%= edu.university %>" placeholder="University name">
              </div>
              <div class="form-group">
                <label><span class="number-prefix">11.</span> Degree / Qualification</label>
                <input type="text" name="education[<%= index %>][degree]" value="<%= edu.degree %>" placeholder="e.g. B.Tech in CS">
              </div>
              <div class="form-group">
                <label><span class="number-prefix">12.</span> Graduation Year</label>
                <input type="text" name="education[<%= index %>][graduationYear]" value="<%= edu.graduationYear %>" placeholder="Year">
              </div>
            </div>
          </div>
        <% }) %>
        <% if (parsedResume.education.length === 0) { %>
          <p style="color: var(--text-muted); text-align: center;">No education history detected.</p>
        <% } %>
      </div>

      <div class="save-button-container">
        <button type="submit" class="btn-submit">Save Profile Changes</button>
      </div>

    </form>
  </div>
</body>
</html>